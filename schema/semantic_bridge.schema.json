{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://qspecbench.org/schema/semantic_bridge.schema.json",
  "title": "QSpecBench Semantic Bridge",
  "type": "object",
  "required": [
    "artifact_gate_model",
    "lean_module",
    "lean_theorem",
    "normalization",
    "claimed_link",
    "wire_order"
  ],
  "properties": {
    "artifact_gate_model": { "type": "string", "minLength": 1 },
    "lean_module": { "type": "string", "minLength": 1 },
    "lean_theorem": { "type": "string", "minLength": 1 },
    "normalization": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "claimed_link": {
      "type": "string",
      "enum": [
        "documented_not_proved",
        "python_denotation_consistency",
        "manifest_checked_theorem_binding",
        "kernel_checked_codegen_trace",
        "kernel_checked_artifact_semantics"
      ]
    },
    "wire_order": {
      "type": "object",
      "required": ["model", "checked_against"],
      "properties": {
        "model": {
          "type": "string",
          "enum": ["legacy_kron_order", "openqasm_little_endian_wire_order"]
        },
        "checked_against": {
          "type": "string",
          "enum": ["lean", "python_operational", "both"]
        }
      },
      "additionalProperties": false
    },
    "wire_order_bridge_theorem": {
      "type": ["string", "null"],
      "description": "Optional Lean theorem id for wire-order alignment proof"
    },
    "artifact_parse_theorem": {
      "type": ["string", "null"],
      "description": "Lean theorem binding on-disk QASM bytes to codegen ops (kernel_checked_artifact_semantics)"
    },
    "target_artifact_parse_theorem": {
      "type": ["string", "null"],
      "description": "Lean parse theorem for target-side kernel artifact when present"
    },
    "theorem_elaborator_hash": {
      "type": ["string", "null"],
      "pattern": "^[a-f0-9]{64}$",
      "description": "SHA-256 of normalized Lean theorem type (v0.3 primary authority; syntactic hash retained as cross-check)"
    },
    "bridge_evidence_id": { "type": ["string", "null"] },
    "gate_set": { "type": ["string", "null"] },
    "qasm_artifact": { "type": "string", "minLength": 1 },
    "gate_model": { "type": "string", "minLength": 1 },
    "artifact_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "gate_trace_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "ast_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "lean_ast_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$",
      "description": "SHA-256 of Lean-mirror canonical AST JSON from parseQasmSource gate list"
    },
    "ast_authority": {
      "type": "string",
      "enum": ["lean_mirror", "python_extract_matrix"],
      "description": "Which AST hash is primary in bridge-codegen verify (kernel bridges: lean_mirror)"
    },
    "generated_lean_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "package_lean_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "theorem_identifier_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "theorem_source_statement_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$",
      "description": "SHA-256 of syntactic Lean theorem statement extraction (secondary cross-check at v0.3)"
    },
    "theorem_content_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$",
      "description": "Deprecated alias for theorem_source_statement_hash"
    },
    "theorem_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "target_qasm_artifact": { "type": "string", "minLength": 1 },
    "target_artifact_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "target_gate_trace_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "target_lean_theorem": { "type": "string", "minLength": 1 },
    "target_ast_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "target_lean_ast_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$",
      "description": "Lean-mirror canonical AST hash for target QASM when dual-manifest target fields are pinned"
    },
    "target_generated_lean_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "pair_lean_theorem": {
      "type": ["string", "null"],
      "description": "Lean theorem id for source-target pair equivalence on dual-manifest compiler bridges"
    }
  },
  "additionalProperties": false
}
