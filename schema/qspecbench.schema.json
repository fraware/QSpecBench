{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://qspecbench.org/schema/qspecbench.schema.json",
  "title": "QSpecBench Specification",
  "type": "object",
  "required": [
    "qspecbench_version",
    "id",
    "title",
    "track",
    "domain",
    "claim_type",
    "difficulty",
    "informal_claim",
    "semantic_level",
    "objects",
    "specification",
    "assumptions",
    "acceptable_evidence",
    "evidence",
    "trust_boundary",
    "status",
    "references"
  ],
  "properties": {
    "qspecbench_version": { "type": "string", "enum": ["0.1", "0.2", "0.3"] },
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
    "title": { "type": "string", "minLength": 1 },
    "track": {
      "type": "string",
      "enum": ["algorithm", "equivalence", "qec", "hamiltonian", "ai_formalization"]
    },
    "domain": { "type": "string", "minLength": 1 },
    "claim_type": { "type": "string", "minLength": 1 },
    "difficulty": {
      "type": "string",
      "enum": ["introductory", "intermediate", "advanced", "frontier"]
    },
    "informal_claim": {
      "type": "object",
      "required": ["statement"],
      "properties": {
        "statement": { "type": "string", "minLength": 1 },
        "source": { "type": ["string", "null"] },
        "reference_key": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "semantic_level": {
      "type": "object",
      "required": ["primary"],
      "properties": {
        "primary": {
          "type": "string",
          "enum": [
            "mathematical",
            "algorithmic",
            "circuit",
            "compiler",
            "qec",
            "physical",
            "protocol",
            "ai_formalization"
          ]
        },
        "secondary": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "objects": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/object_entry" }
    },
    "specification": { "$ref": "#/$defs/specification" },
    "assumptions": { "$ref": "#/$defs/assumptions" },
    "acceptable_evidence": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/acceptable_evidence_entry" }
    },
    "evidence": {
      "type": "array",
      "items": { "$ref": "#/$defs/evidence_entry" }
    },
    "trust_boundary": { "$ref": "#/$defs/trust_boundary" },
    "status": { "$ref": "#/$defs/status" },
    "qec_status": { "$ref": "#/$defs/qec_status" },
    "references": {
      "type": "array",
      "items": { "$ref": "#/$defs/reference_entry" }
    },
    "semantic_bridge": { "$ref": "#/$defs/semantic_bridge" },
    "proof_obligations": {
      "type": "array",
      "items": { "$ref": "#/$defs/proof_obligation" }
    },
    "claim_scope": { "$ref": "#/$defs/claim_scope" },
    "proved_scope": { "$ref": "#/$defs/proved_scope" },
    "headline_claim_status": { "$ref": "#/$defs/headline_claim_status" },
    "formal_claims": {
      "type": "array",
      "items": { "$ref": "#/$defs/formal_claim_entry" }
    },
    "qec_claim_scope": { "$ref": "#/$defs/qec_claim_scope" },
    "ai_formalization_status": { "$ref": "#/$defs/ai_formalization_status" },
    "hamiltonian_claim_scope": { "$ref": "#/$defs/hamiltonian_claim_scope" },
    "provenance": { "$ref": "#/$defs/provenance" },
    "qasm_extraction": { "$ref": "#/$defs/qasm_extraction" },
    "semantics_base": {
      "type": "string",
      "enum": [
        "int_scaffold",
        "complex_matrix",
        "stabilizer_tableau",
        "openqasm_fragment",
        "dynamic_circuit",
        "hamiltonian_operator"
      ]
    }
  },
  "additionalProperties": false,
  "$defs": {
    "evidence_type": {
      "type": "string",
      "enum": [
        "lean_proof",
        "coq_proof",
        "rocq_proof",
        "isabelle_proof",
        "proof_assistant_proof",
        "smt_certificate",
        "sat_certificate",
        "qcec_result",
        "qbricks_result",
        "qec_verifier_result",
        "zx_certificate",
        "simulation",
        "human_review",
        "ai_draft",
        "qasm_parse",
        "python_denotation_consistency_check",
        "other"
      ]
    },
    "object_entry": {
      "type": "object",
      "required": ["name", "type", "format", "role"],
      "properties": {
        "name": { "type": "string" },
        "type": {
          "type": "string",
          "enum": [
            "circuit",
            "program",
            "hamiltonian",
            "stabilizer_code",
            "protocol",
            "theorem",
            "channel",
            "measurement",
            "oracle",
            "decoder",
            "other"
          ]
        },
        "path": { "type": ["string", "null"] },
        "format": {
          "type": "string",
          "enum": [
            "qasm2",
            "qasm3",
            "json",
            "yaml",
            "lean",
            "python",
            "markdown",
            "latex",
            "other"
          ]
        },
        "role": {
          "type": "string",
          "enum": ["source", "target", "specification", "witness", "reference", "generated"]
        }
      },
      "additionalProperties": false
    },
    "specification": {
      "type": "object",
      "required": ["mode", "preconditions", "postconditions", "invariants", "approximation", "resources"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["exact", "approximate", "relational", "temporal", "resource", "negative", "mixed"]
        },
        "preconditions": { "type": "array", "items": { "type": "string" } },
        "postconditions": { "type": "array", "items": { "type": "string" } },
        "invariants": { "type": "array", "items": { "type": "string" } },
        "approximation": { "$ref": "#/$defs/approximation" },
        "resources": { "$ref": "#/$defs/resources" }
      },
      "additionalProperties": false
    },
    "approximation": {
      "type": "object",
      "required": ["enabled"],
      "properties": {
        "enabled": { "type": "boolean" },
        "metric": {
          "type": ["string", "null"],
          "enum": [
            "trace_distance",
            "fidelity",
            "diamond_norm",
            "total_variation",
            "operator_norm",
            "logical_error_rate",
            "other",
            null
          ]
        },
        "bound": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "resources": {
      "type": "object",
      "required": ["enabled"],
      "properties": {
        "enabled": { "type": "boolean" },
        "qubits": { "type": ["string", "null"] },
        "gates": { "type": ["string", "null"] },
        "depth": { "type": ["string", "null"] },
        "t_count": { "type": ["string", "null"] },
        "t_depth": { "type": ["string", "null"] },
        "ancilla": { "type": ["string", "null"] },
        "measurements": { "type": ["string", "null"] },
        "other": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "assumptions": {
      "type": "object",
      "required": ["mathematical", "physical", "tool", "artifact", "unverified"],
      "properties": {
        "mathematical": { "type": "array", "items": { "type": "string" } },
        "physical": { "type": "array", "items": { "type": "string" } },
        "tool": { "type": "array", "items": { "type": "string" } },
        "artifact": { "type": "array", "items": { "type": "string" } },
        "unverified": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "acceptable_evidence_entry": {
      "type": "object",
      "required": ["type", "checker", "required_for_claim", "trust_level"],
      "properties": {
        "type": { "$ref": "#/$defs/evidence_type" },
        "checker": { "type": "string", "minLength": 1 },
        "path": { "type": ["string", "null"] },
        "required_for_claim": { "type": "boolean" },
        "trust_level": {
          "type": "string",
          "enum": [
            "checked",
            "independently_checkable",
            "externally_trusted",
            "heuristic",
            "untrusted"
          ]
        }
      },
      "additionalProperties": false
    },
    "evidence_entry": {
      "type": "object",
      "required": ["id", "type", "path", "checker", "status"],
      "properties": {
        "id": { "type": "string" },
        "type": { "$ref": "#/$defs/evidence_type" },
        "path": { "type": "string" },
        "secondary_path": { "type": ["string", "null"] },
        "checker": { "type": "string" },
        "command": { "type": ["string", "null"] },
        "adapter": { "type": ["string", "null"] },
        "status": {
          "type": "string",
          "enum": ["passing", "failing", "partial", "not_checked", "draft"]
        },
        "notes": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "trust_boundary": {
      "type": "object",
      "required": [
        "checked_by",
        "trusted_kernels",
        "trusted_external_tools",
        "untrusted_components",
        "assumptions_not_checked"
      ],
      "properties": {
        "checked_by": { "type": "array", "items": { "type": "string" } },
        "trusted_kernels": { "type": "array", "items": { "type": "string" } },
        "trusted_external_tools": { "type": "array", "items": { "type": "string" } },
        "untrusted_components": { "type": "array", "items": { "type": "string" } },
        "assumptions_not_checked": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "status": {
      "type": "object",
      "required": [
        "informal_claim",
        "machine_spec",
        "artifacts",
        "evidence",
        "ci",
        "maturity"
      ],
      "properties": {
        "informal_claim": { "type": "string", "enum": ["missing", "draft", "complete"] },
        "machine_spec": { "type": "string", "enum": ["missing", "draft", "complete"] },
        "artifacts": { "type": "string", "enum": ["missing", "partial", "complete"] },
        "evidence": { "type": "string", "enum": ["missing", "partial", "complete"] },
        "ci": { "type": "string", "enum": ["not_applicable", "failing", "passing"] },
        "maturity": {
          "type": "string",
          "enum": [
            "seed",
            "usable",
            "reference_scaffold",
            "reference_contract",
            "reference_artifact",
            "reference_claim",
            "artifact_bound_reference_claim",
            "deprecated"
          ]
        },
        "reviews": { "$ref": "#/$defs/promotion_reviews" }
      },
      "additionalProperties": false
    },
    "promotion_review": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["required", "approved", "rejected", "pending"]
        },
        "reviewer": { "type": ["string", "null"] },
        "review_artifact_sha256": {
          "type": ["string", "null"],
          "pattern": "^[a-f0-9]{64}$",
          "description": "Optional SHA-256 of signed review artifact bundle"
        },
        "date": { "type": ["string", "null"] },
        "notes": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "promotion_reviews": {
      "type": "object",
      "required": ["formal_evidence_review", "domain_semantics_review"],
      "properties": {
        "formal_evidence_review": { "$ref": "#/$defs/promotion_review" },
        "domain_semantics_review": { "$ref": "#/$defs/promotion_review" }
      },
      "additionalProperties": false
    },
    "qec_status": {
      "type": "object",
      "properties": {
        "code_definition": {
          "type": "string",
          "enum": ["missing", "draft", "complete", "checked"]
        },
        "stabilizer_commutation": {
          "type": "string",
          "enum": ["missing", "draft", "complete", "checked"]
        },
        "distance_claim": {
          "type": "string",
          "enum": ["missing", "assumed", "externally_checked", "kernel_checked"]
        },
        "syndrome_extraction": {
          "type": "string",
          "enum": ["missing", "draft", "simulated", "checked"]
        },
        "decoder_claim": {
          "type": "string",
          "enum": ["out_of_scope", "assumed", "simulated", "checked"]
        },
        "correction_claim": {
          "type": "string",
          "enum": ["missing", "draft", "simulated", "checked"]
        },
        "repeated_round_claim": {
          "type": "string",
          "enum": ["out_of_scope", "draft", "checked"]
        }
      },
      "additionalProperties": false
    },
    "reference_entry": {
      "type": "object",
      "required": ["key", "type", "title"],
      "properties": {
        "key": { "type": "string" },
        "type": { "type": "string", "enum": ["paper", "repo", "documentation", "lecture", "other"] },
        "title": { "type": "string" },
        "url": { "type": ["string", "null"] },
        "notes": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "semantic_bridge": {
      "$ref": "semantic_bridge.schema.json"
    },
    "proof_obligation": {
      "type": "object",
      "required": ["id", "status"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "status": {
          "type": "string",
          "enum": ["missing", "partial", "passing", "not_applicable"]
        },
        "notes": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "claim_scope": {
      "type": "object",
      "required": ["headline_claim_id", "headline_claim_text", "required_obligations"],
      "properties": {
        "headline_claim_id": { "type": "string", "minLength": 1 },
        "headline_claim_text": { "type": "string", "minLength": 1 },
        "required_obligations": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": false
    },
    "proved_scope": {
      "type": "object",
      "required": ["checked_obligations", "unproved_obligations"],
      "properties": {
        "checked_obligations": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "unproved_obligations": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": false
    },
    "headline_claim_status": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["unproved", "partially_checked", "checked"]
        },
        "notes": { "type": ["string", "null"] },
        "checked_under": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "not_checked_under": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": false
    },
    "formal_claim_entry": {
      "type": "object",
      "required": ["id", "evidence_id", "formal_system", "theorem", "supports", "does_not_support"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "evidence_id": { "type": "string", "minLength": 1 },
        "formal_system": {
          "type": "string",
          "enum": ["lean", "coq", "rocq", "isabelle", "other"]
        },
        "module": { "type": ["string", "null"] },
        "theorem": { "type": "string", "minLength": 1 },
        "supports": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "does_not_support": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "benchmark_anchor": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "qec_claim_scope": {
      "type": "object",
      "properties": {
        "code_schema": {
          "type": "string",
          "enum": ["checked", "unchecked", "draft"]
        },
        "code_definition_semantics": {
          "type": "string",
          "enum": ["checked", "unchecked", "draft"]
        },
        "stabilizer_commutation": {
          "type": "string",
          "enum": ["checked", "unchecked", "draft"]
        },
        "syndrome_table": {
          "type": "string",
          "enum": ["checked", "unchecked", "draft", "assumed"]
        },
        "correction_table": {
          "type": "string",
          "enum": ["checked", "unchecked", "draft", "assumed"]
        },
        "decoder_algorithm": {
          "type": "string",
          "enum": ["checked", "checked_lookup_table", "assumed", "out_of_scope"]
        },
        "logical_preservation_small_code": {
          "type": "string",
          "enum": ["checked", "assumed", "out_of_scope"]
        },
        "logical_preservation_general": {
          "type": "string",
          "enum": ["checked", "assumed", "out_of_scope"]
        },
        "qec_certificate_level": {
          "type": "string",
          "enum": [
            "qec_small_code_checked",
            "qec_external_certificate_checked",
            "qec_family_checked"
          ]
        },
        "distance": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "enum": [
                "quantum_distance",
                "x_distance",
                "z_distance",
                "bit_flip_distance",
                "declared_parameter"
              ]
            },
            "status": {
              "type": "string",
              "enum": ["checked", "assumed", "toy", "declared_only"]
            }
          },
          "additionalProperties": false
        },
        "repeated_rounds": {
          "type": "string",
          "enum": ["checked", "draft", "out_of_scope"]
        }
      },
      "additionalProperties": false
    },
    "ai_formalization_status": {
      "type": "object",
      "properties": {
        "syntax_valid": { "type": "boolean" },
        "kernel_checked": { "type": "boolean" },
        "semantic_reviewed": { "type": "boolean" },
        "faithfulness_score": { "type": ["integer", "null"], "minimum": 0, "maximum": 5 },
        "library_compatible": { "type": "boolean" },
        "proof_completed": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "hamiltonian_claim_scope": {
      "type": "object",
      "required": ["claim_class"],
      "properties": {
        "claim_class": {
          "type": "string",
          "enum": [
            "matrix_identity_claim",
            "hermiticity_claim",
            "mapping_sanity_claim",
            "declared_contract_claim",
            "analytic_error_bound_claim"
          ]
        },
        "derivation_status": {
          "type": "string",
          "enum": ["checked", "declared_only", "reviewed", "not_applicable"]
        }
      },
      "additionalProperties": false
    },
    "qasm_extraction": {
      "type": "object",
      "required": ["mode", "allowed_to_skip"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "unitary_fragment",
            "dynamic_fragment_recording",
            "full_dynamic_semantics",
            "syntax_only"
          ]
        },
        "allowed_to_skip": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "measurement",
              "reset",
              "classical_control",
              "gate_def",
              "declaration",
              "structural"
            ]
          }
        }
      },
      "additionalProperties": false
    },
    "provenance": {
      "type": "object",
      "properties": {
        "generated_at": { "type": ["string", "null"] },
        "artifacts": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["path", "sha256"],
            "properties": {
              "path": { "type": "string" },
              "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
              "role": { "type": ["string", "null"] }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  }
}
