{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://qspecbench.org/schema/qec_witness.schema.json",
  "title": "QSpecBench QEC Witness",
  "type": "object",
  "required": ["method"],
  "properties": {
    "method": { "type": "string", "minLength": 1 },
    "syndrome_table_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "correction_table_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "syndrome_table_path": { "type": "string", "minLength": 1 },
    "correction_table_path": { "type": "string", "minLength": 1 },
    "complete_for": { "type": "string", "minLength": 1 },
    "proof_artifact_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "min_distance": { "type": "integer" },
    "commutes": { "type": "boolean" },
    "over_claim": { "type": "boolean" }
  },
  "additionalProperties": true
}
